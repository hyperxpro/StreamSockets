# syntax=docker/dockerfile:1.7

# ─── Base images (digest-pinned) ────────────────────────────────────────────
# Pinned digest of `rust:1.86-bookworm` resolved 2026-05-01 against Docker Hub.
# Bump on Dependabot; the digest is the immutable source of truth, the tag in
# the comment is a human-readable reminder of which release this points at.
# To re-pin: `docker buildx imagetools inspect rust:1.86-bookworm` and copy
# the index digest.
ARG RUST_BASE=rust@sha256:300ec56abce8cc9448ddea2172747d048ed902a3090e6b57babb2bf19f754081
# Pinned digest of `gcr.io/distroless/cc-debian12:nonroot` resolved 2026-05-01.
# To re-pin: `docker buildx imagetools inspect gcr.io/distroless/cc-debian12:nonroot`.
ARG RUNTIME_BASE=gcr.io/distroless/cc-debian12@sha256:e2d29aec8061843706b7e484c444f78fafb05bfe47745505252b1769a05d14f1

# ─── Stage 1: cargo-chef planner ────────────────────────────────────────────
# cargo-chef caches the dependency-only build artifact; subsequent code
# changes only re-link the workspace crates instead of rebuilding the full
# dep graph (~5–10 min savings per CI build).
FROM ${RUST_BASE} AS chef
RUN cargo install --locked cargo-chef@0.1.68
WORKDIR /src

FROM chef AS planner
COPY . .
RUN cargo chef prepare --recipe-path recipe.json

# ─── Stage 2: build (cached deps + workspace) ───────────────────────────────
FROM chef AS builder
ARG TARGETARCH
RUN apt-get update && apt-get install -y --no-install-recommends \
    cmake pkg-config && rm -rf /var/lib/apt/lists/*
COPY --from=planner /src/recipe.json recipe.json
# `cargo chef cook` builds *only* the dependency graph for the recipe.
# `-C target-cpu=x86-64-v3` is meaningful only on amd64 (Haswell+ baseline);
# on arm64 the flag is meaningless and rustc emits a warning, so gate on
# TARGETARCH so multi-arch builds don't carry dead flags.
RUN if [ "${TARGETARCH}" = "amd64" ]; then \
        export RUSTFLAGS="-C target-cpu=x86-64-v3"; \
    fi && \
    cargo chef cook --release --recipe-path recipe.json --bin streamsockets-server
COPY . .
RUN if [ "${TARGETARCH}" = "amd64" ]; then \
        export RUSTFLAGS="-C target-cpu=x86-64-v3"; \
    fi && \
    cargo build --release --locked --bin streamsockets-server

# ─── Stage 3: runtime ───────────────────────────────────────────────────────
FROM ${RUNTIME_BASE}
COPY --from=builder /src/target/release/streamsockets-server /usr/local/bin/streamsockets-server

# accounts.yml is not baked in — operators mount it at /etc/streamsockets/accounts.yml.
ENV ACCOUNTS_CONFIG_FILE=/etc/streamsockets/accounts.yml \
    DISABLE_IOURING=true \
    LOG_FORMAT=json \
    LOG_LEVEL=info

EXPOSE 8080/tcp 9090/tcp
USER nonroot
# No HEALTHCHECK directive: distroless has no shell utilities (wget/curl/sh),
# so a CMD probe would have nothing to invoke. The orchestrator (k8s,
# docker-compose) is expected to probe `http://<host>:9090/healthz` directly
# via its own native HTTP probe — that is the canonical mechanism in v2 and
# avoids baking a redundant probe binary into the image.
ENTRYPOINT ["/usr/local/bin/streamsockets-server"]
