# syntax=docker/dockerfile:1.7

# ─── Base images (digest-pinned) ────────────────────────────────────────────
# See `Dockerfile-Server-Rust` for the rationale on digest-pinning vs tags.
# Bump these in lockstep with the server Dockerfile.
ARG RUST_BASE=rust@sha256:300ec56abce8cc9448ddea2172747d048ed902a3090e6b57babb2bf19f754081
ARG RUNTIME_BASE=gcr.io/distroless/cc-debian12@sha256:e2d29aec8061843706b7e484c444f78fafb05bfe47745505252b1769a05d14f1

# ─── Stage 1: cargo-chef planner ────────────────────────────────────────────
FROM ${RUST_BASE} AS chef
ARG TARGETARCH
ENV RUSTFLAGS_AMD64="-C target-cpu=x86-64-v3"
ENV CARGO_TERM_COLOR=always
RUN --mount=type=cache,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,target=/usr/local/cargo/git,sharing=locked \
    cargo install --locked cargo-chef@0.1.68
WORKDIR /src

FROM chef AS planner
COPY . .
RUN cargo chef prepare --recipe-path recipe.json

# ─── Stage 2: build (cached deps + workspace) ───────────────────────────────
FROM chef AS builder
RUN apt-get update && apt-get install -y --no-install-recommends \
    cmake pkg-config && rm -rf /var/lib/apt/lists/*
COPY --from=planner /src/recipe.json recipe.json
RUN --mount=type=cache,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,target=/usr/local/cargo/git,sharing=locked \
    --mount=type=cache,target=/src/target,sharing=locked,id=streamsockets-client-target \
    if [ "${TARGETARCH}" = "amd64" ]; then export RUSTFLAGS="${RUSTFLAGS_AMD64}"; fi && \
    cargo chef cook --release --recipe-path recipe.json --bin streamsockets-client
COPY . .
RUN --mount=type=cache,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,target=/usr/local/cargo/git,sharing=locked \
    --mount=type=cache,target=/src/target,sharing=locked,id=streamsockets-client-target \
    if [ "${TARGETARCH}" = "amd64" ]; then export RUSTFLAGS="${RUSTFLAGS_AMD64}"; fi && \
    cargo build --release --locked --bin streamsockets-client && \
    cp /src/target/release/streamsockets-client /usr/local/bin/streamsockets-client

# ─── Stage 3: runtime ───────────────────────────────────────────────────────
FROM ${RUNTIME_BASE}
COPY --from=builder /usr/local/bin/streamsockets-client /usr/local/bin/streamsockets-client

ENV DISABLE_IOURING=true \
    LOG_FORMAT=json \
    LOG_LEVEL=info

EXPOSE 8888/udp
USER nonroot
ENTRYPOINT ["/usr/local/bin/streamsockets-client"]
