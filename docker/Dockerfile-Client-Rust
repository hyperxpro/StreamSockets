# Stage 1: build
FROM rust:1.86-bookworm AS build
WORKDIR /src
RUN apt-get update && apt-get install -y --no-install-recommends \
    cmake pkg-config && rm -rf /var/lib/apt/lists/*
COPY . .
ENV RUSTFLAGS="-C target-cpu=x86-64-v3"
RUN cargo build --release --locked --bin streamsockets-client

# Stage 2: runtime
FROM gcr.io/distroless/cc-debian12:nonroot
COPY --from=build /src/target/release/streamsockets-client /usr/local/bin/streamsockets-client

ENV DISABLE_IOURING=true \
    LOG_FORMAT=json \
    LOG_LEVEL=info

EXPOSE 9000/udp
USER nonroot
ENTRYPOINT ["/usr/local/bin/streamsockets-client"]
